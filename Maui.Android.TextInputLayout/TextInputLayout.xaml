<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:input="clr-namespace:Maui.Android.TextInputLayout"
             x:Name="this"
             x:Class="Maui.Android.TextInputLayout.TextInputLayout">
    <input:TextInputEditText x:Name="textInputEditText" BindingContext="{Binding Source={x:Reference this}}" BackgroundColor="{Binding BackgroundColor}" Text="{Binding Text}" />
</ContentView>
