<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="Maui.Android.TextInputLayout.TextInputLayout"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:input="clr-namespace:Maui.Android.TextInputLayout"
    x:Name="this">
    <input:TextInputEditText
        x:Name="textInputEditText"
        BackgroundColor="{Binding BackgroundColor}"
        BindingContext="{Binding Source={x:Reference this}}"
        BoxBackgroundMode="{Binding BoxBackgroundMode}"
        Text="{Binding Text}" />
</ContentView>
