<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiCustomControls.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:custom="clr-namespace:MauiCustomControls"
    xmlns:input="clr-namespace:Maui.Android.TextInputLayout;assembly=Maui.Android.TextInputLayout"
    x:Name="root"
    BackgroundColor="#1d1b20"
    Shell.BackgroundColor="#101010"
    Shell.TitleColor="#19f50a">
    <!--  BackgroundColor="{DynamicResource md.comp.filled-text-field.container.color}"  -->
    <ScrollView>
        <VerticalStackLayout
            x:Name="test"
            Padding="30,0"
            Spacing="8">

            <Image
                Aspect="AspectFit"
                HeightRequest="185"
                SemanticProperties.Description="dot net bot in a race car number eight"
                Source="dotnet_bot.png" />
            <input:TextInputLayout
                
                BoxBackgroundMode="Outline"
                >
                <input:MaterialEntry
                     />
            </input:TextInputLayout>
            <!--  EndIcon="dotnet_bot"  -->
            <input:TextInputLayout
                x:Name="textinputlayout1"
                BorderColor="#79747E"
                BoxBackgroundMode="Filled"
                DefaultHintColor="#49454F"
                EndIconColor="#49454F"
                EndIconVisibilityMode="WhileEditing"
                FocusedBorderColor="#6750A4"
                FocusedHintColor="#6750A4"
                Hint="Outline"
                IsEnabled="True"
                Text="{Binding EntryText}"
                TextColor="{Binding OutlineEntryColor}">
                <input:MaterialEntry
                    BackgroundColor="#E6E0E9"
                    FontFamily="Roboto"
                    Text="{Binding EntryText}"
                    TextColor="#1D1B20" />
            </input:TextInputLayout>
            <input:TextInputLayout
                x:Name="textinputlayout2"
                BorderColor="#79747E"
                BoxBackgroundMode="Outline"
                DefaultHintColor="#49454F"
                EndIconColor="#49454F"
                EndIconVisibilityMode="WhileEditing"
                FocusedBorderColor="#6750A4"
                FocusedHintColor="#6750A4"
                Hint="Outline"
                IsEnabled="True"
                Text="{Binding EntryText}"
                TextColor="{Binding OutlineEntryColor}">
                <input:MaterialEntry TextColor="#E6E0E9" />
            </input:TextInputLayout>
            <input:TextInputLayout
                BackgroundColor="Black"
                BorderColor="{Binding OutlineEntryColor}"
                BoxBackgroundMode="Filled"
                DefaultHintColor="Red"
                EndIconColor="#FFFFFF"
                EndIconVisibilityMode="WhileEditing"
                FocusedBorderColor="{Binding OutlineEntryColor}"
                FocusedHintColor="{Binding OutlineEntryColor}"
                Hint="Outline"
                IsEnabled="True"
                IsHintAnimated="False"
                Text="{Binding EntryText}"
                TextColor="{Binding OutlineEntryColor}">
                <input:MaterialPicker
                    Title="Test"
                    BackgroundColor="#101010"
                    TextColor="#FFFFFF"
                    TitleColor="#FFFFFF">
                    <Picker.ItemsSource>
                        <x:Array Type="{x:Type x:String}">
                            <x:String>Baboon</x:String>
                            <x:String>Capuchin Monkey</x:String>
                            <x:String>Blue Monkey</x:String>
                            <x:String>Squirrel Monkey</x:String>
                            <x:String>Golden Lion Tamarin</x:String>
                            <x:String>Howler Monkey</x:String>
                            <x:String>Japanese Macaque</x:String>
                        </x:Array>
                    </Picker.ItemsSource>
                </input:MaterialPicker>
            </input:TextInputLayout>
            <Picker
                Title="Select a monkey"
                TextColor="White"
                TitleColor="White">
                <Picker.ItemsSource>
                    <x:Array Type="{x:Type x:String}">
                        <x:String>Baboon</x:String>
                        <x:String>Capuchin Monkey</x:String>
                        <x:String>Blue Monkey</x:String>
                        <x:String>Squirrel Monkey</x:String>
                        <x:String>Golden Lion Tamarin</x:String>
                        <x:String>Howler Monkey</x:String>
                        <x:String>Japanese Macaque</x:String>
                    </x:Array>
                </Picker.ItemsSource>
            </Picker>
            <!--<input:TextInputLayout
                x:Name="testEntry"
                BackgroundColor="Black"
                BorderColor="{Binding OutlineEntryColor}"
                BoxBackgroundMode="Outline"
                DefaultHintColor="Red"
                EndIconColor="#FFFFFF"
                EndIconVisibilityMode="WhileEditing"
                FocusedBorderColor="{Binding OutlineEntryColor}"
                FocusedHintColor="{Binding OutlineEntryColor}"
                Hint="Outline"
                IsEnabled="{Binding IsEntryEnabled}"
                Placeholder=""
                PlaceholderColor="White"
                Text="{Binding EntryText}"
                TextColor="{Binding OutlineEntryColor}" />
            <input:TextInputLayout
                BackgroundColor="Black"
                BorderColor="{Binding OutlineEntryColor}"
                BoxBackgroundMode="Outline"
                DefaultHintColor="{Binding OutlineEntryColor}"
                EndIconColor="#FFFFFF"
                EndIconVisibilityMode="WhileEditing"
                FocusedBorderColor="{Binding OutlineEntryColor}"
                FocusedHintColor="{Binding OutlineEntryColor}"
                Hint="Outline"
                Text="{Binding EntryText}"
                TextColor="{Binding OutlineEntryColor}" />

            <Grid RowDefinitions="Auto, Auto">
                <input:TextInputLayout
                    Grid.Row="0"
                    BackgroundColor="Transparent"
                    BorderColor="#19f50a"
                    BoxBackgroundMode="Filled"
                    DefaultHintColor="#19f50a"
                    EndIcon="ic_clear_2"
                    EndIconVisibilityMode="Always"
                    FocusedBorderColor="#19f50a"
                    FocusedHintColor="#19f50a"
                    Hint="Filled Hidden"
                    IsEnabled="False"
                    IsVisible="False"
                    Text="{Binding EntryText}"
                    TextColor="White" />
                <input:TextInputLayout
                    Grid.Row="1"
                    BackgroundColor="Transparent"
                    BorderColor="#19f50a"
                    BoxBackgroundMode="Filled"
                    DefaultHintColor="#19f50a"
                    EndIcon="ic_clear_2"
                    EndIconVisibilityMode="Always"
                    FocusedBorderColor="#19f50a"
                    FocusedHintColor="#19f50a"
                    Hint="Filled"
                    IsEnabled="False"
                    Text="{Binding EntryText}"
                    TextColor="White" />
            </Grid>
            <input:TextInputLayout
                BackgroundColor="White"
                BorderColor="Blue"
                BoxBackgroundMode="None"
                EndIcon="dotnet_bot2"
                EndIconVisibilityMode="Never"
                Hint="None"
                Text="{Binding EntryText}" />-->
            <Entry />
            <!--<input:TextInputLayout BackgroundColor="Transparent" BorderColor="AliceBlue" FocusedBorderColor="Red" Hint="Test Hint" DefaultHintColor="Blue" FocusedHintColor="Red" IsHintAnimated="False" />
            <input:TextInputLayout BackgroundColor="Blue"  />
            <input:TextInputEditText />
            <input:TextInputLayout Hint="Layout">
                <input:TextInputEditText />
            </input:TextInputLayout>-->
            <Label
                SemanticProperties.HeadingLevel="Level1"
                Style="{StaticResource Headline}"
                Text="Hello, World!" />

            <Label
                SemanticProperties.Description="Welcome to dot net Multi platform App U I"
                SemanticProperties.HeadingLevel="Level2"
                Style="{StaticResource SubHeadline}"
                Text="Welcome to &#10;.NET Multi-platform App UI" />

            <Button
                x:Name="CounterBtn"
                Command="{Binding ButtonClickedCommand}"
                HorizontalOptions="Fill"
                SemanticProperties.Hint="Counts the number of times you click"
                Text="Click me" />

            <CollectionView ItemsSource="{Binding Pages}">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Button
                            Command="{Binding BindingContext.GoToPageCommand, Source={x:Reference root}}"
                            CommandParameter="{Binding}"
                            Text="{Binding}" />
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
            <!--<custom:CustomEntry />-->
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
