<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiCustomControls.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:custom="clr-namespace:MauiCustomControls"
    xmlns:input="clr-namespace:Maui.Android.TextInputLayout;assembly=Maui.Android.TextInputLayout"
    BackgroundColor="#101010"
    Shell.BackgroundColor="#101010"
    Shell.TitleColor="#19f50a">

    <ScrollView>
        <VerticalStackLayout
            x:Name="test"
            Padding="30,0"
            Spacing="8">

            <Image
                Aspect="AspectFit"
                HeightRequest="185"
                SemanticProperties.Description="dot net bot in a race car number eight"
                Source="dotnet_bot.png" />

            <!--  EndIcon="dotnet_bot"  -->
            <input:TextInputLayout
                x:Name="testEntry"
                BackgroundColor="Black"
                BorderColor="{Binding OutlineEntryColor}"
                BoxBackgroundMode="Outline"
                DefaultHintColor="Red"
                EndIconColor="#FFFFFF"
                EndIconVisibilityMode="WhileEditing"
                FocusedBorderColor="{Binding OutlineEntryColor}"
                FocusedHintColor="{Binding OutlineEntryColor}"
                Hint="Outline"
                IsEnabled="False"
                Text="{Binding EntryText}"
                TextColor="{Binding OutlineEntryColor}" />
            <input:TextInputLayout
                BackgroundColor="Black"
                BorderColor="{Binding OutlineEntryColor}"
                BoxBackgroundMode="Outline"
                DefaultHintColor="{Binding OutlineEntryColor}"
                EndIconColor="#FFFFFF"
                EndIconVisibilityMode="WhileEditing"
                FocusedBorderColor="{Binding OutlineEntryColor}"
                FocusedHintColor="{Binding OutlineEntryColor}"
                Hint="Outline"
                Text="{Binding EntryText}"
                TextColor="{Binding OutlineEntryColor}" />

            <input:TextInputLayout
                BackgroundColor="Transparent"
                BorderColor="#19f50a"
                BoxBackgroundMode="Filled"
                DefaultHintColor="#19f50a"
                EndIcon="ic_clear_2"
                EndIconVisibilityMode="Always"
                FocusedBorderColor="#19f50a"
                FocusedHintColor="#19f50a"
                Hint="Filled"
                Text="{Binding EntryText}"
                TextColor="White" />

            <input:TextInputLayout
                BackgroundColor="White"
                BorderColor="Blue"
                BoxBackgroundMode="None"
                EndIcon="dotnet_bot2"
                EndIconVisibilityMode="Never"
                Hint="None"
                Text="{Binding EntryText}" />
            <Entry />
            <!--<input:TextInputLayout BackgroundColor="Transparent" BorderColor="AliceBlue" FocusedBorderColor="Red" Hint="Test Hint" DefaultHintColor="Blue" FocusedHintColor="Red" IsHintAnimated="False" />
            <input:TextInputLayout BackgroundColor="Blue"  />
            <input:TextInputEditText />
            <input:TextInputLayout Hint="Layout">
                <input:TextInputEditText />
            </input:TextInputLayout>-->
            <Label
                SemanticProperties.HeadingLevel="Level1"
                Style="{StaticResource Headline}"
                Text="Hello, World!" />

            <Label
                SemanticProperties.Description="Welcome to dot net Multi platform App U I"
                SemanticProperties.HeadingLevel="Level2"
                Style="{StaticResource SubHeadline}"
                Text="Welcome to &#10;.NET Multi-platform App UI" />

            <Button
                x:Name="CounterBtn"
                Command="{Binding ButtonClickedCommand}"
                HorizontalOptions="Fill"
                SemanticProperties.Hint="Counts the number of times you click"
                Text="Click me" />
            <!--<custom:CustomEntry />-->
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
