<?xml version="1.0" encoding="utf-8" ?>
<base:BaseDemoPage
    x:Class="Nwesp.Maui.Android.Samples.PasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:Nwesp.Maui.Android.Samples"
    xmlns:input="clr-namespace:Nwesp.Maui.Android.Controls;assembly=Nwesp.Maui.Android"
    Title="PasswordPage">
    <ScrollView>
        <VerticalStackLayout Padding="8" Spacing="40">

            <input:TextInputLayout
                BoxBackgroundMode="{Binding BoxBackgroundMode}"
                Hint="Select End Icon Visibility mode"
                SupportingText="Select a mode to apply the visibility to the entries below">
                <input:MaterialPicker ItemsSource="{Binding IconVisibilityModes}" SelectedItem="{Binding SelectedIconVisibilityMode}" />
            </input:TextInputLayout>

            <input:TextInputLayout
                BoxBackgroundMode="{Binding BoxBackgroundMode}"
                EndIconMode="Password"
                EndIconVisibilityMode="{Binding SelectedIconVisibilityMode}"
                Hint="Password"
                IsHintAlwaysExpanded="True"
                SupportingText="Password enabled by default. No Text">
                <input:MaterialEntry IsPassword="True" />
            </input:TextInputLayout>
            <input:TextInputLayout
                BoxBackgroundMode="{Binding BoxBackgroundMode}"
                EndIconMode="Password"
                EndIconVisibilityMode="{Binding SelectedIconVisibilityMode}"
                Hint="Password"
                IsHintAlwaysExpanded="True"
                SupportingText="Password enabled by default. Has Text">
                <input:MaterialEntry IsPassword="True" Text="Password" />
            </input:TextInputLayout>

            <input:TextInputLayout
                BoxBackgroundMode="{Binding BoxBackgroundMode}"
                EndIconMode="Password"
                EndIconVisibilityMode="{Binding SelectedIconVisibilityMode}"
                Hint="Password"
                IsHintAlwaysExpanded="True"
                SupportingText="Password disabled by default. No Text">
                <input:MaterialEntry />
            </input:TextInputLayout>
            <input:TextInputLayout
                BoxBackgroundMode="{Binding BoxBackgroundMode}"
                EndIconMode="Password"
                EndIconVisibilityMode="{Binding SelectedIconVisibilityMode}"
                Hint="Password"
                IsHintAlwaysExpanded="True"
                SupportingText="Password disabled by default. Has Text">
                <input:MaterialEntry Text="Password" />
            </input:TextInputLayout>
            <input:TextInputLayout
                BoxBackgroundMode="{Binding BoxBackgroundMode}"
                EndIconMode="Password"
                EndIconVisibilityMode="{Binding SelectedIconVisibilityMode}"
                Hint="Password"
                IsHintAlwaysExpanded="True"
                SupportingText="Numeric Password enabled by default. No Text">
                <input:MaterialEntry IsPassword="True" Keyboard="Numeric" />
            </input:TextInputLayout>
            <input:TextInputLayout
                BoxBackgroundMode="{Binding BoxBackgroundMode}"
                EndIconMode="Password"
                EndIconVisibilityMode="{Binding SelectedIconVisibilityMode}"
                Hint="Password"
                IsHintAlwaysExpanded="True"
                SupportingText="Numeric Password enabled by default. Has Text">
                <input:MaterialEntry
                    IsPassword="True"
                    Keyboard="Numeric"
                    Text="1234" />
            </input:TextInputLayout>
        </VerticalStackLayout>
    </ScrollView>
</base:BaseDemoPage>