<?xml version="1.0" encoding="utf-8" ?>
<base:BaseDemoPage
    x:Class="Nwesp.Maui.Android.Samples.PasswordPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:base="clr-namespace:Nwesp.Maui.Android.Samples"
    xmlns:input="clr-namespace:Nwesp.Maui.Android.Controls;assembly=Nwesp.Maui.Android"
    Title="PasswordPage">
    <ScrollView>
        <VerticalStackLayout Padding="8" Spacing="8">

            <input:TextInputLayout BoxBackgroundMode="{Binding BoxBackgroundMode}" Hint="Select End Icon mode">
                <input:MaterialPicker ItemsSource="{Binding Items}" SelectedItem="{Binding SelectedIconVisibilityMode}" />
            </input:TextInputLayout>

            <input:TextInputLayout
                BoxBackgroundMode="{Binding BoxBackgroundMode}"
                EndIconMode="Password"
                EndIconVisibilityMode="{Binding SelectedIconVisibilityMode}"
                Hint="Is Password No Text">
                <input:MaterialEntry IsPassword="True" />
            </input:TextInputLayout>
            <input:TextInputLayout
                BoxBackgroundMode="{Binding BoxBackgroundMode}"
                EndIconMode="Password"
                EndIconVisibilityMode="{Binding SelectedIconVisibilityMode}"
                Hint="Is Password Has Text">
                <input:MaterialEntry IsPassword="True" Text="Password" />
            </input:TextInputLayout>

            <input:TextInputLayout
                BoxBackgroundMode="{Binding BoxBackgroundMode}"
                EndIconMode="Password"
                EndIconVisibilityMode="{Binding SelectedIconVisibilityMode}"
                Hint="No Text">
                <input:MaterialEntry />
            </input:TextInputLayout>
            <input:TextInputLayout
                BoxBackgroundMode="{Binding BoxBackgroundMode}"
                EndIconMode="Password"
                EndIconVisibilityMode="{Binding SelectedIconVisibilityMode}"
                Hint="Has Text">
                <input:MaterialEntry Text="Password" />
            </input:TextInputLayout>
            <input:TextInputLayout
                BoxBackgroundMode="{Binding BoxBackgroundMode}"
                EndIconMode="Password"
                EndIconVisibilityMode="{Binding SelectedIconVisibilityMode}"
                Hint="Numeric Password">
                <input:MaterialEntry IsPassword="True" Keyboard="Numeric" />
            </input:TextInputLayout>
        </VerticalStackLayout>
    </ScrollView>
</base:BaseDemoPage>